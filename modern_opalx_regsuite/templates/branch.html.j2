<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Branch {{ branch }} - OPALX Regression</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        margin: 0;
        padding: 2rem;
        background: #020617;
        color: #e5e7eb;
      }
      h1 {
        margin-top: 0;
        margin-bottom: 1rem;
      }
      table {
        border-collapse: collapse;
        width: 100%;
        margin-top: 1rem;
      }
      th,
      td {
        border-bottom: 1px solid rgba(148, 163, 184, 0.35);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-size: 0.9rem;
      }
      th {
        font-weight: 600;
        color: #d1d5db;
      }
      .status-badge {
        display: inline-block;
        padding: 0.1rem 0.5rem;
        border-radius: 999px;
        font-size: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.6);
      }
      .status-passed {
        background: rgba(22, 163, 74, 0.15);
        border-color: rgba(22, 163, 74, 0.9);
      }
      .status-failed {
        background: rgba(220, 38, 38, 0.15);
        border-color: rgba(220, 38, 38, 0.9);
      }
      a {
        color: #38bdf8;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .muted {
        color: #9ca3af;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <a href="../../index.html" class="muted">&larr; All branches</a>
    <h1>Branch {{ branch }}</h1>
    {% for arch, runs in runs_by_arch.items() %}
    <h2 style="margin-top: 1.5rem; font-size: 1.1rem">Architecture: {{ arch }}</h2>
    {% if runs %}
    <table>
      <thead>
        <tr>
          <th>Run ID</th>
          <th>Status</th>
          <th>Started</th>
          <th>Results</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for run in runs %}
        <tr>
          <td>{{ run.run_id }}</td>
          <td>
            {% set cls = "status-badge" %}
            {% if run.status == "passed" %}
            {% set cls = cls + " status-passed" %}
            {% elif run.status != "running" %}
            {% set cls = cls + " status-failed" %}
            {% endif %}
            <span class="{{ cls }}">{{ run.status }}</span>
          </td>
          <td>{{ run.started_at }}</td>
          <td>
            {% if run.unit_tests_total %}Unit: {{ run.unit_tests_total - run.unit_tests_failed }}/{{ run.unit_tests_total }}{% else %}Unit: {% if run.unit_tests_failed %}{{ run.unit_tests_failed }} failed{% else %}-{% endif %}{% endif %},
            {% if run.regression_total %}Reg: {{ run.regression_passed }}/{{ run.regression_total }}{% if run.regression_broken %}, {{ run.regression_broken }} broken{% endif %}{% else %}Reg: {% if run.regression_failed or run.regression_broken %}{{ run.regression_failed }} failed{% endif %}{% endif %}
          </td>
          <td>
            <a href="{{ arch }}/{{ run.run_id }}/">Details</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="muted">No runs for this architecture yet.</p>
    {% endif %} {% endfor %}
  </body>
</html>

