<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>OPALX Regression Dashboard</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        margin: 0;
        padding: 2rem;
        background: #020617;
        color: #e5e7eb;
      }
      h1 {
        margin-top: 0;
        margin-bottom: 1rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
      }
      .card {
        background: #020617;
        border-radius: 0.75rem;
        padding: 1rem 1.2rem;
        border: 1px solid rgba(148, 163, 184, 0.35);
      }
      .status-badge {
        display: inline-block;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        font-size: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.6);
      }
      .status-passed {
        background: rgba(22, 163, 74, 0.15);
        border-color: rgba(22, 163, 74, 0.9);
      }
      .status-failed {
        background: rgba(220, 38, 38, 0.15);
        border-color: rgba(220, 38, 38, 0.9);
      }
      a {
        color: #38bdf8;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .muted {
        color: #9ca3af;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <h1>OPALX Regression Dashboard</h1>
    <p class="muted">Latest runs per branch and architecture.</p>
    <div class="grid">
      {% for run in latest_runs %}
      <div class="card">
        <div>
          <strong>{{ run.branch }}</strong>
          <span class="muted">/ {{ run.arch }}</span>
        </div>
        <div style="margin-top: 0.4rem">
          {% set cls = "status-badge" %}
          {% if run.status == "passed" %}
          {% set cls = cls + " status-passed" %}
          {% elif run.status != "running" %}
          {% set cls = cls + " status-failed" %}
          {% endif %}
          <span class="{{ cls }}">{{ run.status }}</span>
        </div>
        <div class="muted" style="margin-top: 0.4rem">
          Started: {{ run.started_at }}
        </div>
        <div class="muted">
          {% if run.unit_tests_total %}Unit: {{ run.unit_tests_total - run.unit_tests_failed }}/{{ run.unit_tests_total }} passed{% else %}Unit: {% if run.unit_tests_failed %}{{ run.unit_tests_failed }} failed{% else %}-{% endif %}{% endif %}<br/>
          {% if run.regression_total %}Reg: {{ run.regression_passed }}/{{ run.regression_total }} passed{% if run.regression_broken %}, {{ run.regression_broken }} broken{% endif %}{% else %}Reg: {% if run.regression_failed or run.regression_broken %}{{ run.regression_failed }} failed, {{ run.regression_broken }} broken{% else %}-{% endif %}{% endif %}
        </div>
        <div style="margin-top: 0.6rem">
          <a href="branch/{{ run.branch }}/">Branch overview</a>
        </div>
      </div>
      {% else %}
      <p>No runs found yet. Run <code>opalx-regsuite run</code> to create data.</p>
      {% endfor %}
    </div>
  </body>
</html>

